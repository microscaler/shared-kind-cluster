    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 102,
      "panels": [],
      "title": "Cache + preemption",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (host) (rate(vllm_prefix_cache_hits_total{cluster=\"cylon-sparks\", host=~\"$host\", model_name=~\"$model\"}[5m])) / clamp_min(sum by (host) (rate(vllm_prefix_cache_queries_total{cluster=\"cylon-sparks\", host=~\"$host\", model_name=~\"$model\"}[5m])), 0.0001)", "legendFormat": "{{host}}", "refId": "A" }
      ],
      "title": "Prefix cache hit rate (5m)",
      "description": "vllm:prefix_cache_hits / vllm:prefix_cache_queries. Higher = more KV reuse across requests with shared prefixes (system prompts, agent loops).",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "ops", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.1 }] }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 25 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (host) (rate(vllm_num_preemptions_total{cluster=\"cylon-sparks\", host=~\"$host\", model_name=~\"$model\"}[5m]))", "legendFormat": "{{host}}", "refId": "A" }
      ],
      "title": "Preemptions/sec (5m)",
      "description": "vllm:num_preemptions. Non-zero = the scheduler had to preempt running requests to make room (KV cache pressure).",
      "type": "timeseries"
    }
  ]
}
