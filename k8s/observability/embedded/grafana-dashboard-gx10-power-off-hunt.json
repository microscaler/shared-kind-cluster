  "id": null,
  "uid": "gx10-power-off-hunt",
  "title": "DGX Spark — GX10 abrupt-power-off hunt",
  "tags": ["sparks", "cylon", "forensics", "gx10", "abrupt-power-off"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "browser",
  "description": "Focused forensic dashboard for the recurring GX10 abrupt-power-off issue tracked in cylon-local-infra/llmwiki/runs/2026-05-01-nvidia2-abrupt-power-off-vllm-long-context.md and NVIDIA forum #359785. Combines DCGM (power, temp, throttle), rasdaemon (EDAC + PCIe AER + MCE), vLLM concurrent in-flight (the multi-Hermes-session amplifier), and the kernel/dockerd journal (mlx5 LINK DOWN, MCE, panic, OOM) on a single time axis so the next crash leaves a complete forensic record.",
  "links": [
    { "title": "Postmortem (cylon-local-infra)", "url": "https://github.com/microscaler/cylon-local-infra/tree/main/llmwiki/runs/2026-05-01-nvidia2-abrupt-power-off-vllm-long-context.md", "targetBlank": true, "type": "link" },
    { "title": "NVIDIA forum #359785", "url": "https://forums.developer.nvidia.com/t/title-asus-ascent-gx10-gb10-hard-power-off-unclean-reboot-under-vllm-gpt-oss-120b-long-context/359785", "targetBlank": true, "type": "link" }
  ],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values({cluster=\"cylon-sparks\"}, host)",
        "includeAll": true,
        "multi": true,
        "name": "host",
        "options": [],
        "query": { "query": "label_values({cluster=\"cylon-sparks\"}, host)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Status (read this row first when triaging a crash)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "min by (host) (up{cluster=\"cylon-sparks\", host=~\"$host\"})", "legendFormat": "{{host}}", "refId": "A" }],
      "title": "Spark up/down",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "time() - node_boot_time_seconds{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}}", "refId": "A" }],
      "title": "Uptime (since last boot)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^os_kernel$/", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (host, os_kernel) (up{cluster=\"cylon-sparks\", host=~\"$host\"})", "format": "table", "instant": true, "refId": "A" }],
      "title": "Running kernel",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (host, category) (rasdaemon_events_total{cluster=\"cylon-sparks\", host=~\"$host\", category=~\"memory_ce|memory_ue|pcie_aer_correctable|pcie_aer_uncorrectable|pcie_aer_fatal|mce_records\"})", "legendFormat": "{{host}} {{category}}", "refId": "A" }],
      "title": "RAS event counters (any > 0 = investigate)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (host) (DCGM_FI_DEV_XID_ERRORS{cluster=\"cylon-sparks\", host=~\"$host\"})", "legendFormat": "{{host}}", "refId": "A" }],
      "title": "GPU XID errors (any > 0 = NVIDIA driver-level fault)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 100 }] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (host) (DCGM_FI_DEV_PCIE_REPLAY_COUNTER_total{cluster=\"cylon-sparks\", host=~\"$host\"})", "legendFormat": "{{host}}", "refId": "A" }],
      "title": "PCIe replay counter (steady increase = link flap)",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": [],
      "title": "GPU power + thermal (forum #359785: long context = sustained high power = trigger window)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 150 }, { "color": "orange", "value": 200 }, { "color": "red", "value": 240 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "DCGM_FI_DEV_POWER_USAGE{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} gpu{{gpu}}", "refId": "A" }],
      "title": "GPU power draw (15s)",
      "description": "Forum #359785 strong correlation: sustained > 200W during long-context inference precedes the abrupt power-off. The TGP envelope of GB10 is around 240W.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "orange", "value": 85 }, { "color": "red", "value": 90 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "DCGM_FI_DEV_GPU_TEMP{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} GPU core", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "DCGM_FI_DEV_MEMORY_TEMP{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} GPU mem", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (host, chip) (node_hwmon_temp_celsius{cluster=\"cylon-sparks\", host=~\"$host\"})", "legendFormat": "{{host}} {{chip}}", "refId": "C" }
      ],
      "title": "GPU + SoC temperatures",
      "description": "GB10 thermal throttle threshold ~85C. SoC sensors (node_hwmon) show peripheral hot zones — useful for ruling thermal in/out as a crash cause.",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 },
      "id": 102,
      "panels": [],
      "title": "RAS events (rasdaemon → node_exporter textfile, 60s tick)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "normal" } }
        },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rasdaemon_events_total{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} {{category}}", "refId": "A" }],
      "title": "rasdaemon counters by category (cumulative since rasdaemon start)",
      "description": "Categories: memory_ce/memory_ue (EDAC), pcie_aer_correctable/uncorrectable/fatal, mce_records, extlog_records, devlink_records. Any non-zero is signal — uncorrectable / fatal = stop everything and investigate.",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "panels": [],
      "title": "vLLM load (the multi-Hermes-session amplifier)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15, "stacking": { "mode": "none" } } }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 26 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "vllm_num_requests_running{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} running", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "vllm_num_requests_waiting{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} waiting", "refId": "B" }
      ],
      "title": "Concurrent vLLM requests (running + waiting)",
      "description": "Multi-Hermes-session amplifier: this is the single biggest software-side correlate with the abrupt power-off. Anything > 8 sustained while GPU power is also high is the suspected trigger window.",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 26 },
      "id": 31,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max", "lastNotNull"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "vllm_kv_cache_usage_perc{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}}", "refId": "A" }],
      "title": "KV cache occupancy (UMA-allocated → counts as host RAM pressure on GB10)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 104,
      "panels": [],
      "title": "Logs (Loki) — the kernel/dockerd grep we kept doing manually post-incident",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 36 },
      "id": 40,
      "options": { "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true, "enableLogDetails": true, "showCommonLabels": false, "dedupStrategy": "none" },
      "targets": [{ "datasource": { "type": "loki", "uid": "loki" }, "expr": "{cluster=\"cylon-sparks\", host=~\"$host\"} |~ \"(?i)(mlx5|MCE|panic|aer|oom|hardlockup|softlockup|nvidia.*xid|vbios|gpu fallen|uncorrected|hard.*power.*off|abrupt|reset)\"", "refId": "A" }],
      "title": "Kernel + dockerd events matching crash signatures",
      "description": "Live scan for the patterns that kept showing up in our post-incident post-hoc journal greps: mlx5 LINK DOWN, MCE, kernel panic, PCIe AER, OOM, NVIDIA XID, VBIOS errors, GPU 'fallen off the bus', uncorrected ECC, hard power-off, abrupt shutdown, reset.",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 48 },
      "id": 41,
      "options": { "showLabels": false, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true, "enableLogDetails": true, "showCommonLabels": false, "dedupStrategy": "none" },
      "targets": [{ "datasource": { "type": "loki", "uid": "loki" }, "expr": "{cluster=\"cylon-sparks\", host=~\"$host\", container_name=~\"vllm-ngc-ray-.*\"}", "refId": "A" }],
      "title": "vLLM container logs (head + worker, all hosts)",
      "type": "logs"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 56 },
      "id": 105,
      "panels": [],
      "title": "Interconnect + driver-level signals",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 57 },
      "id": 50,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(DCGM_FI_DEV_NVLINK_BANDWIDTH_TOTAL_total{cluster=\"cylon-sparks\", host=~\"$host\"}[5m])", "legendFormat": "{{host}} gpu{{gpu}}", "refId": "A" }],
      "title": "NVLink bandwidth (rate)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 57 },
      "id": 51,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(node_network_receive_bytes_total{cluster=\"cylon-sparks\", host=~\"$host\", device=~\"rocep.*|enp1s0f0np0|enp.*\"}[1m])", "legendFormat": "{{host}} {{device}} rx", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "-rate(node_network_transmit_bytes_total{cluster=\"cylon-sparks\", host=~\"$host\", device=~\"rocep.*|enp1s0f0np0|enp.*\"}[1m])", "legendFormat": "{{host}} {{device}} tx", "refId": "B" }
      ],
      "title": "QSFP / RoCE interface throughput (rx +, tx -)",
      "description": "If a Spark goes silent on the QSFP fabric just before the crash, the link drop will show up here. Cross-reference with mlx5 LINK DOWN events in the log panel.",
      "type": "timeseries"
    }
  ]
