{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "spark-cluster-overview",
  "title": "DGX Spark Cluster — Overview",
  "tags": ["sparks", "cylon", "gpu", "host"],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "links": [],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values({cluster=\"cylon-sparks\"}, host)",
        "includeAll": true,
        "multi": true,
        "name": "host",
        "options": [],
        "query": { "query": "label_values({cluster=\"cylon-sparks\"}, host)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values({cluster=\"cylon-sparks\"}, os_kernel)",
        "includeAll": true,
        "multi": true,
        "name": "os_kernel",
        "options": [],
        "query": { "query": "label_values({cluster=\"cylon-sparks\"}, os_kernel)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 2,
        "regex": "",
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Fleet status (cluster=cylon-sparks)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "min by (host) (up{cluster=\"cylon-sparks\", host=~\"$host\"})", "legendFormat": "{{host}}", "refId": "A" }],
      "title": "Spark up/down",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/^os_kernel$/", "values": false }, "textMode": "value_and_name" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (host, os_kernel) (up{cluster=\"cylon-sparks\", host=~\"$host\"})", "format": "table", "instant": true, "refId": "A" }],
      "title": "Running kernel (per host)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "time() - node_boot_time_seconds{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}}", "refId": "A" }],
      "title": "Uptime",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "OK" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (host) (rasdaemon_events_total{cluster=\"cylon-sparks\", host=~\"$host\"})", "legendFormat": "{{host}}", "refId": "A" }],
      "title": "Total RAS events (cumulative)",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "panels": [],
      "title": "GPU (DCGM)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "watt",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "DCGM_FI_DEV_POWER_USAGE{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} gpu{{gpu}}", "refId": "A" }],
      "title": "GPU power draw",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 85 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "DCGM_FI_DEV_GPU_TEMP{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} GPU core", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "DCGM_FI_DEV_MEMORY_TEMP{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} GPU mem", "refId": "B" }
      ],
      "title": "GPU temperature (core + memory)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "DCGM_FI_DEV_GPU_UTIL{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} SM util", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "DCGM_FI_DEV_MEM_COPY_UTIL{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} mem copy util", "refId": "B" }
      ],
      "title": "GPU utilization",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "MHz", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 13,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "DCGM_FI_DEV_SM_CLOCK{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} SM clock", "refId": "A" }
      ],
      "title": "GPU SM clock",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "panels": [],
      "title": "Host CPU + memory",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "1 - avg by (host) (rate(node_cpu_seconds_total{cluster=\"cylon-sparks\", host=~\"$host\", mode=\"idle\"}[1m]))", "legendFormat": "{{host}} CPU busy", "refId": "A" }
      ],
      "title": "CPU utilization (1 - idle, avg across cores)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "1 - (node_memory_MemAvailable_bytes{cluster=\"cylon-sparks\", host=~\"$host\"} / node_memory_MemTotal_bytes{cluster=\"cylon-sparks\", host=~\"$host\"})", "legendFormat": "{{host}} mem used (UMA — also GPU memory)", "refId": "A" }
      ],
      "title": "Host memory utilization (Grace UMA — shared with GPU)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "id": 22,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "node_load1{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} load1", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "node_load5{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} load5", "refId": "B" }
      ],
      "title": "Load average",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "celsius", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 0 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "id": 23,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "node_hwmon_temp_celsius{cluster=\"cylon-sparks\", host=~\"$host\"}", "legendFormat": "{{host}} {{chip}} {{sensor}}", "refId": "A" }
      ],
      "title": "Host hwmon temperatures (SoC sensors)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "id": 103,
      "panels": [],
      "title": "Network + filesystem",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "rate(node_network_receive_bytes_total{cluster=\"cylon-sparks\", host=~\"$host\", device!~\"lo|veth.*|br-.*|docker.*\"}[1m])", "legendFormat": "{{host}} {{device}} rx", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "-rate(node_network_transmit_bytes_total{cluster=\"cylon-sparks\", host=~\"$host\", device!~\"lo|veth.*|br-.*|docker.*\"}[1m])", "legendFormat": "{{host}} {{device}} tx", "refId": "B" }
      ],
      "title": "Network throughput (rx +, tx -)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 15 }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.85 }, { "color": "red", "value": 0.95 }] } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "id": 31,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "1 - (node_filesystem_avail_bytes{cluster=\"cylon-sparks\", host=~\"$host\", mountpoint=~\"/|/home|/var/lib/docker\"} / node_filesystem_size_bytes{cluster=\"cylon-sparks\", host=~\"$host\", mountpoint=~\"/|/home|/var/lib/docker\"})", "legendFormat": "{{host}} {{mountpoint}}", "refId": "A" }
      ],
      "title": "Filesystem usage (key mounts)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "id": 104,
      "panels": [],
      "title": "systemd unit health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "mappings", "value": [{ "options": { "0": { "color": "red", "index": 0, "text": "STOPPED" } }, "type": "value" }, { "options": { "1": { "color": "green", "index": 1, "text": "RUNNING" } }, "type": "value" }] }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }] }
        ]
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 49 },
      "id": 40,
      "options": { "showHeader": true },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max by (host, name) (node_systemd_unit_state{cluster=\"cylon-sparks\", host=~\"$host\", state=\"active\"})", "format": "table", "instant": true, "refId": "A" }
      ],
      "title": "Tracked systemd units (vllm-*, hf-prefetch, ngc-image-sync, otel-agent, promtail, dcgm-exporter, ...)",
      "type": "table",
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "cluster": true, "instance": true, "job": true, "service_name": true, "service_instance_id": true, "exported_instance": true, "exported_job": true, "http_scheme": true, "net_host_port": true, "os_distribution": true, "os_kernel": true, "type": true }, "renameByName": { "name": "unit", "host": "host" } } }
      ]
    }
  ]
}
